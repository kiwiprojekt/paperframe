<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>paperframe_server</RootNamespace>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Flurl.Http" Version="4.0.2" />
      <PackageReference Include="Ical.Net" Version="5.2.1" />
      <PackageReference Include="Magick.NET-Q8-AnyCPU" Version="14.13.1" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="StaticAssets\" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="StaticAssets\**" />
      <Content Include="StaticAssets\**">
          <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
          <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      </Content>
    </ItemGroup>

</Project>
